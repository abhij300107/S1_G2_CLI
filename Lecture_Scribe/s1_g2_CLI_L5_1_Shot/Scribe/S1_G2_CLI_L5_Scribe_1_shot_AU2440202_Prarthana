\section{Illustrative Applications}

\subsection*{Example 3.1 (Insurance Policy)}

\textbf{Given:}
\begin{itemize}[leftmargin=*]
    \item $\Pr(A_1 \mid A) = 0.4$
    \item $\Pr(A_1 \mid A^c) = 0.2$
    \item $\Pr(A) = 0.3$
\end{itemize}

\textbf{Result:}
\[
\Pr(A_1) = (0.4)(0.3) + (0.2)(0.7) = 0.26
\]

\textbf{Conditional Probability:}
\[
\Pr(A \mid A_1) = \frac{(0.3)(0.4)}{0.26} = \frac{6}{13}
\]

\vspace{1em}
\subsection*{Example 3.2 (Colored Cards)}

\[
\Pr(\text{other side is black} \mid \text{red observed}) = \frac{1}{3}
\]

\vspace{1em}
\subsection*{Random Variable Example (Three Coin Tosses)}

Let $Y$ = number of heads.
\[
\Pr(Y = 0) = \frac{1}{8}, \quad
\Pr(Y = 1) = \frac{3}{8}, \quad
\Pr(Y = 2) = \frac{3}{8}, \quad
\Pr(Y = 3) = \frac{1}{8}
\]

