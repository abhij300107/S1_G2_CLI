\section{Core Results}

\subsection{Weighted Average of Conditional Probabilities}

\[
\Pr(A) = \Pr(A \mid B)\Pr(B) + \Pr(A \mid B^c)[1 - \Pr(B)]
\]

\vspace{0.8em}
\subsection{Law of Total Probability (Formula 3.4)}

For events $B_1, B_2, \ldots, B_n$ forming a partition:
\[
\Pr(A) = \sum_i \Pr(A \mid B_i)\Pr(B_i)
\]

\vspace{0.8em}
\subsection{Bayes’ Formula (Proposition 3.1)}

\[
\Pr(B_i \mid A) =
\frac{\Pr(A \mid B_i)\Pr(B_i)}
{\sum_j \Pr(A \mid B_j)\Pr(B_j)}
\]

\begin{itemize}[leftmargin=*]
    \item $\Pr(B_i)$ : Apriori probability
    \item $\Pr(B_i \mid A)$ : Posteriori probability
\end{itemize}

\vspace{0.5em}
\subsection{Probability Mass Function}

For a discrete random variable $X$ with range $\{x_1, x_2, \ldots\}$:
\[
p(x_k) = \Pr(X = x_k)
\]
\[
\sum_k p(x_k) = 1
\]

\newpage
\section{Analytical Development}

\subsection{Derivation of Weighted Average Formula}

\begin{itemize}[leftmargin=*]
    \item Since $AB$ and $AB^c$ are mutually exclusive:
    \[
    \Pr(A) = \Pr(AB) + \Pr(AB^c)
    \]
    \item Using conditional probability:
    \[
    \Pr(A) = \Pr(A \mid B)\Pr(B) + \Pr(A \mid B^c)\Pr(B^c)
    \]
\end{itemize}

\vspace{0.5em}
\subsection{Derivation of Bayes’ Formula}

\begin{itemize}[leftmargin=*]
    \item Using:
    \[
    \Pr(AB_i) = \Pr(A \mid B_i)\Pr(B_i)
    \]
    \item Substitute into law of total probability and rearrange.
\end{itemize}

